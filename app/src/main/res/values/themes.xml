<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme – no ActionBar, we draw our own UI -->
    <style name="Theme.LibreDisplay" parent="android:Theme.Material.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.LibreDisplay.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="postSplashScreenTheme">@style/Theme.LibreDisplay</item>
    </style>
</resources>

